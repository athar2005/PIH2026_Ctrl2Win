<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- LOGO -->
        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/logo"
            android:layout_marginTop="20dp"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verification Result"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp"/>

        <!-- RESULT CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginTop="24dp"
            android:elevation="6dp">

            <TextView
                android:id="@+id/resultText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payment Safe ✅"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#00FFC6"/>

            <TextView
                android:id="@+id/confidenceText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Confidence : 95%"
                android:textColor="#FFFFFF"
                android:layout_marginTop="8dp"/>

            <TextView
                android:id="@+id/riskStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOW RISK"
                android:textColor="#00FFC6"
                android:textStyle="bold"
                android:layout_marginTop="6dp"/>

        </LinearLayout>

        <!-- ANALYSIS CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI Analysis"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="18sp"/>

            <TextView
                android:id="@+id/reasonText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#D0D7E2"
                android:layout_marginTop="10dp"/>

        </LinearLayout>

        <!-- SECURITY CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="18dp"
            android:layout_marginTop="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Security Verification"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Bank-level Screenshot Analysis"
                android:textColor="#00FFC6"
                android:layout_marginTop="6dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✔ Hybrid AI Verification Enabled"
                android:textColor="#00FFC6"/>

        </LinearLayout>

        <!-- TIMESTAMP -->
        <TextView
            android:id="@+id/timeStamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="13sp"
            android:layout_marginTop="20dp"/>

        <!-- BACK BUTTON -->
        <Button
            android:id="@+id/homeBtn"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="BACK TO HOME"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/button_primary"
            android:layout_marginTop="24dp"/>

        <!-- FOOTER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0 • AI Secure Build"
            android:textColor="#7F8DA3"
            android:textSize="12sp"
            android:layout_marginTop="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 PaySafeAI • All Rights Reserved"
            android:textColor="#7F8DA3"
            android:textSize="12sp"/>

    </LinearLayout>

</ScrollView>