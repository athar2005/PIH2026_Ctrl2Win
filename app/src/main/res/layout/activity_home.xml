<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A192F">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- APP LOGO -->
        <ImageView
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:src="@drawable/logo"
            android:layout_marginTop="20dp"/>

        <!-- WELCOME -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome 👋"
            android:textColor="#9FB3C8"
            android:textSize="18sp"
            android:layout_marginTop="12dp"/>

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Verify Payment"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:textSize="30sp"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="40dp"/>

        <!-- ================= MAIN CARD ================= -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/card_background"
            android:orientation="vertical"
            android:padding="24dp"
            android:elevation="8dp"
            android:gravity="center_horizontal">

            <!-- TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Upload Payment Screenshot"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="20sp"
                android:gravity="center"
                android:textAlignment="center"/>

            <!-- SUBTEXT -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AI detects fake or real payments instantly"
                android:textColor="#A8B2D1"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textAlignment="center"/>

            <!-- ✅ GLOW CONTAINER -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:background="@drawable/button_glow"
                android:padding="3dp">

                <!-- ✅ SCAN BUTTON -->
                <Button
                    android:id="@+id/uploadBtn"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:text="SCAN PAYMENT"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/button_primary"/>

            </FrameLayout>

        </LinearLayout>

        <!-- ================= FOOTER ================= -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Secure AI Payment Verification"
            android:textColor="#00FFC6"
            android:textSize="13sp"
            android:layout_marginTop="50dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Version 1.0 • AI Secure Build"
            android:textColor="#7F8DA3"
            android:textSize="12sp"
            android:layout_marginTop="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="© 2026 PaySafeAI • All Rights Reserved"
            android:textColor="#7F8DA3"
            android:textSize="12sp"
            android:layout_marginTop="4dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI verification is advisory and intended for fraud risk indication only."
            android:textColor="#5F6E85"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:paddingBottom="20dp"/>

    </LinearLayout>

</ScrollView>